{
  "name": "issue-board",
  "version": "0.0.1",
  "private": true,
  "description": "Claude 에이전트가 기획·와이어프레임·이슈 분리를 수행하고 로컬 대시보드로 시각화하는 웹 애플리케이션",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @issue-board/server dev",
    "dev:web": "pnpm --filter @issue-board/web dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @issue-board/shared build",
    "db:migrate": "pnpm --filter @issue-board/server db:migrate",
    "db:generate": "pnpm --filter @issue-board/server db:generate",
    "db:sync": "pnpm --filter @issue-board/server db:sync",
    "db:studio": "pnpm --filter @issue-board/server db:studio"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "@swc/core",
      "esbuild"
    ]
  }
}

// Issue Board — 로컬 전용 SQLite 스키마
// 상세 설계: docs/ARCHITECTURE.md §3

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  // 외부 Claude 세션이 cwd로 프로젝트를 매칭하기 위한 로컬 경로
  repoPath    String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans      Plan[]
  issues     Issue[]
  wireframes Wireframe[]
  domains    Domain[]
  design     Design?
  activities ActivityLog[]
  dailySummaries DailySummary[]
}

// 이슈보드 변경 이력(감사 로그). REST/MCP 어느 경로의 write든 Service 계층에서 한 행씩 기록.
// 일일 업무 요약(ib-daily)의 원천 데이터. 이 테이블 도입 시점 이후부터 온전히 쌓인다.
model ActivityLog {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // project | plan | issue | domain | wireframe | design
  entityType String
  entityId   String
  // created | updated | status_changed | snapshot | linked | deleted
  action     String
  // 사람이 읽을 대상 이름/제목 (스냅샷 — 대상이 나중에 삭제돼도 남는다)
  title      String
  // 변경 상세 JSON: { field: { from, to } }. 없으면 null
  changes    String?
  // user(웹) | agent(MCP/Claude)
  source     String   @default("agent")
  createdAt  DateTime @default(now())

  @@index([projectId, createdAt])
}

// Claude(CLI)가 그날의 활동 로그(스냅샷)를 읽어 서술한 일일 업무 요약.
// 프론트의 규칙 기반 렌더(dailyReport.ts)와 달리, LLM이 "무슨 작업이 이뤄졌는지"를 서술한다.
// 수동('AI 요약하기' 버튼) 또는 스케줄(매일 cron)로 생성되며 projectId+date로 upsert(재생성=갱신).
model DailySummary {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // 대상 날짜 (요청 타임존 기준 YYYY-MM-DD)
  date      String
  timezone  String   @default("Asia/Seoul")
  // Claude가 생성한 서술형 마크다운 본문 (status=ready일 때만 유효)
  content   String   @default("")
  // 사용 모델(claude CLI 기본값이면 null일 수 있음)
  model     String?
  // pending(생성 중) | ready(완료) | error(실패)
  status    String   @default("ready")
  // status=error일 때 원인 메시지
  error     String?
  // 요약 시점 활동 건수 (0이면 요약 생략 대상)
  activityCount Int  @default(0)
  // manual(버튼) | schedule(cron)
  createdBy String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, date])
  @@index([projectId])
}

// 프로젝트당 하나의 디자인 시스템 (색·타이포·간격 등 토큰). 이름 대신 프로젝트로 upsert.
model Design {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // 디자인 토큰 JSON (DesignTokens)
  tokens    String   @default("{}")
  status    String   @default("draft") // draft | approved | archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  // 마크다운 기획서 본문 (사용자 편집 가능)
  content   String
  status    String   @default("draft") // draft | approved | archived
  version   Int      @default(1) // 낙관적 잠금 + 현재 버전 번호
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issues   Issue[]
  versions PlanVersion[]

  @@index([projectId])
}

// 기획 변경 이력 스냅샷 (버전 관리). 모든 create/update마다 한 행씩 쌓인다.
// 기획 마일스톤 스냅샷. 매 편집이 아니라 승인/명시적 저장 시에만 생성된다.
model PlanVersion {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  version   Int // 마일스톤 번호 (1,2,3…) — Plan.version(편집 카운터)과는 별개
  title     String
  content   String
  status    String
  label     String? // 스냅샷 사유/이름 (예: "승인", "MVP 범위 확정")
  createdAt DateTime @default(now())

  @@unique([planId, version])
  @@index([planId])
}

model Issue {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  body      String
  // 에픽(상위) vs 태스크(하위) 명시 구분
  type      String   @default("task") // epic | task
  status    String   @default("todo") // todo | in_progress | done | blocked
  // 우선순위는 value/effort에서 산출된다 (derivePriority)
  priority  String   @default("medium") // low | medium | high
  value     String   @default("medium") // 가치 low | medium | high
  effort    String   @default("medium") // 노력 low | medium | high
  labels    String   @default("[]") // JSON 문자열 (SQLite는 배열 미지원)
  // 이슈 트리 (기획 → 이슈 분리)
  parentId  String?
  parent    Issue?   @relation("IssueTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Issue[]  @relation("IssueTree")
  // 연동: 파생된 기획, 관련 와이어프레임 화면(프로토타입의 data-screen id), 관련 도메인
  planId    String?
  plan      Plan?    @relation(fields: [planId], references: [id], onDelete: SetNull)
  screenId  String?
  domainId  String?
  domain    Domain?  @relation(fields: [domainId], references: [id], onDelete: SetNull)
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([parentId])
  @@index([planId])
  @@index([domainId])
}

model Domain {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  // 컬럼 정의 배열 JSON: [{ name, type, constraints?, description? }]
  columns     String   @default("[]")
  // 상태 생명주기 JSON: { states?: [{name,description?}], transitions: [{from,to,on?}] }. 없으면 null
  lifecycle   String?
  // 첫 설계는 초안. draft | approved | archived
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  issues Issue[]

  // 편집형 upsert: 프로젝트 내 이름은 유일
  @@unique([projectId, name])
  @@index([projectId])
}

model Wireframe {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  // 조회 전용 (편집 대상 아님) — html | excalidraw | mermaid | svg
  format    String   @default("html")
  content   String
  // IA(정보구조) 순서. 왼쪽 네비가 오름차순 정렬. 낮을수록 위.
  sequence  Int      @default(0)
  // 같은 name의 재생성마다 증가. 삭제 대신 이력으로 보존한다.
  version   Int      @default(1)
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, name])
}
